[configuration]
entry_symbol = "gdext_rust_init"
compatibility_minimum = 4.1
reloadable = true

[libraries]
linux.debug.x86_64 = "res://rust/target/debug/libdragoon_plugin.so"
linux.release.x86_64 = "res://rust/target/release/libdragoon_plugin.so"
windows.debug.x86_64 = "res://rust/target/debug/dragoon_plugin.dll"
windows.release.x86_64 = "res://rust/target/release/dragoon_plugin.dll"
macos.debug = "res://rust/target/debug/libdragoon_plugin.dylib"
macos.release = "res://rust/target/release/libdragoon_plugin.dylib"
macos.debug.arm64 = "res://rust/target/debug/libdragoon_plugin.dylib"
macos.release.arm64 = "res://rust/target/release/libdragoon_plugin.dylib"
